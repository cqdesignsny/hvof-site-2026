# HVOF site environment variables
# Copy this to .env.local for local development.
# In production, set these via `vercel env add` or the Vercel dashboard.

# --- Public (browser-exposed) ---

# Google Analytics 4 measurement ID (looks like G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=

# Meta (Facebook) Pixel ID — numeric only
NEXT_PUBLIC_FB_PIXEL_ID=

# Optional: override the canonical site URL for metadata + sitemap.
# Defaults to value in src/lib/site.ts when not set.
# NEXT_PUBLIC_SITE_URL=https://hvof-site-2026.vercel.app

# --- Server-only (do NOT prefix with NEXT_PUBLIC) ---

# Resend transactional email (used by /api/lead route)
RESEND_API_KEY=
LEAD_EMAIL_TO=cesar@creativequalitymarketing.com
LEAD_EMAIL_FROM="HVOF Site <noreply@thewowguys.com>"

# Optional: Typeform embed URL — used in contact CTA fallback
NEXT_PUBLIC_TYPEFORM_URL=

# --- Floorplan admin (the /admin backend) ---

# Single shared password for the /admin gate. Pick something strong.
ADMIN_PASSWORD=

# Long random string used to sign the admin session cookie. 32+ characters.
# Generate with: openssl rand -hex 32
ADMIN_SESSION_SECRET=
